<h1> Novo horário </h1>
<% if @slot.errors.any? %>
  <div style="color: red">
    <% @slot.errors.full_messages.each do |msg| %>
      <p><%= msg %></p>
    <% end %>
  </div>
<% end %>

<%= form_with model: @slot do |f| %>

 <p>
    <%= f.label :date, "Data" %><br>
    <%= f.date_field :date %>
  </p>

  <p>
    <%= f.label :start_time, "Horário" %><br>
    <%= f.time_field :start_time %>
  </p>

  <p>
    <%= f.label :available, "Disponível" %>
    <%= f.check_box :available %>
  </p>

  <%= f.submit "Salvar horário" %>
<% end %>

<a href="/slots">Voltar </a>