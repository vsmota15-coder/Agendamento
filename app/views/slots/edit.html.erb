<div class="row justify-content-center">
  <div class="col-md-6">
    <h1 class="mb-4">Horário editado</h1>

    <% if @slot.errors.any? %>
      <div class="alert alert-danger">
        <% @slot.errors.full_messages.each do |msg| %>
          <p class="mb-0"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="card">
      <div class="card-body">
        <%= form_with model: @slot do |f| %>
          <div class="mb-3">
            <%= f.label :date, "Data", class: "form-label" %>
            <%= f.date_field :date, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :start_time, "Horário", class: "form-label" %>
            <%= f.time_field :start_time, class: "form-control" %>
          </div>

          <div class="mb-3 form-check">
            <%= f.check_box :available, class: "form-check-input" %>
            <%= f.label :available, "Disponível", class: "form-check-label" %>
          </div>

          <%= f.submit "Editar horário", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>

    <a href="/slots" class="btn btn-outline-secondary mt-3">Voltar</a>
  </div>
</div>