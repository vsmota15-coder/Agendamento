<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Horários disponíveis</h1>
  <a href="/slots/new" class="btn btn-primary">Adicionar horário</a>
</div>

<% @slots.each do |slot| %>
  <div class="card mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
      <div>
        <h5 class="card-title mb-1"><%= slot.date.strftime("%d/%m/%Y") %> às <%= slot.start_time.strftime("%H:%M") %></h5>
        <% if slot.available %>
          <span class="badge bg-success">Disponível</span>
        <% else %>
          <span class="badge bg-danger">Ocupado</span>
        <% end %>
      </div>
      <div class="d-flex gap-2">
        <% if slot.available %>
          <a href="/bookings/new" class="btn btn-success btn-sm">Agendar</a>
        <% end %>
        <a href="/slots/<%= slot.id %>/edit" class="btn btn-outline-secondary btn-sm">Editar</a>
        <%= button_to "Deletar", slot_path(slot), method: :delete, class: "btn btn-outline-danger btn-sm", data: { turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  </div>
<% end %>


