<div class="row justify-content-center">
  <div class="col-md-6">
    <h1 class="mb-4">Fazer agendamento</h1>

    <% if @booking.errors.any? %>
      <div class="alert alert-danger">
        <% @booking.errors.full_messages.each do |msg| %>
          <p class="mb-0"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="card">
      <div class="card-body">
        <%= form_with model: @booking do |f| %>
          <div class="mb-3">
            <%= f.label :name, "Seu nome", class: "form-label" %>
            <%= f.text_field :name, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :phone, "Seu telefone", class: "form-label" %>
            <%= f.text_field :phone, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :slot_id, "Horário", class: "form-label" %>
            <%= f.collection_select :slot_id, @slots, :id, :date, {}, { class: "form-select" } %>
          </div>

          <%= f.submit "Confirmar agendamento", class: "btn btn-success w-100" %>
        <% end %>
      </div>
    </div>

    <a href="/slots" class="btn btn-outline-secondary mt-3">Voltar</a>
  </div>
</div>