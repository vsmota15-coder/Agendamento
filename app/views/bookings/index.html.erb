<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Agendamentos</h1>
</div>

<% if @bookings.empty? %>
  <div class="alert alert-info">Nenhum agendamento ainda.</div>
<% else %>
  <div class="card">
    <table class="table table-hover mb-0">
      <thead class="table-dark">
        <tr>
          <th>Nome</th>
          <th>Telefone</th>
          <th>Data</th>
          <th>Horário</th>
        </tr>
      </thead>
      <tbody>
        <% @bookings.each do |booking| %>
          <tr>
            <td><%= booking.name %></td>
            <td><%= booking.phone %></td>
            <td><%= booking.slot.date.strftime("%d/%m/%Y") %></td>
            <td><%= booking.slot.start_time.strftime("%H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>